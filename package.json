{
  "name": "melonjs-typescript-boilerplate",
  "version": "2.1.0",
  "main": "dist-electron/main.js",
  "author": "Olivier Biot",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "vite dev --config vite.electron.config.ts",
    "electron:build": "tsc && vite build --config vite.electron.config.ts",
    "electron:dist": "npm run electron:build && electron-builder"
  },
  "build": {
    "appId": "com.melonjs.boilerplate",
    "productName": "melonJS Game",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "melonjs": "^19.0.0"
  },
  "devDependencies": {
    "@melonjs/debug-plugin": "^15.0.3",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-static-copy": "^4.0.1"
  }
}
